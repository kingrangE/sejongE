# 임베딩 + 답변 생성 모두 OpenAI 사용 (필수)
OPENAI_API_KEY=sk-...

# (선택) Claude를 LLM으로 쓸 때만 필요. 기본 경로는 OpenAI라 없어도 됨.
# ANTHROPIC_API_KEY=sk-ant-...

# 모델 설정
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
LLM_MODEL=gpt-4o-mini

# 저장 경로 (기본값: backend/data 하위)
# DATA_DIR=./data

# 크롤 예의 설정
CRAWL_USER_AGENT=SejongRAGBot/0.1 (+contact: your-email@example.com)
CRAWL_MAX_CONCURRENCY=2
CRAWL_MIN_DELAY_SEC=1.0
CRAWL_MAX_DELAY_SEC=3.0

# 시간대
TIMEZONE=Asia/Seoul

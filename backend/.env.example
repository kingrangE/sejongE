# LLM / 임베딩 API 키 (필수)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# 모델 설정
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
LLM_MODEL=claude-opus-4-8
LLM_MODEL_CHEAP=claude-haiku-4-5

# 저장 경로 (기본값: backend/data 하위)
# DATA_DIR=./data

# 크롤 예의 설정
CRAWL_USER_AGENT=SejongRAGBot/0.1 (+contact: your-email@example.com)
CRAWL_MAX_CONCURRENCY=2
CRAWL_MIN_DELAY_SEC=1.0
CRAWL_MAX_DELAY_SEC=3.0

# 시간대
TIMEZONE=Asia/Seoul
